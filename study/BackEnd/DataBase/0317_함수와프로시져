# 프로시져
```
DELIMITER //

CREATE PROCEDURE pl_total(
    IN a VARCHAR(100), 
     IN b VARCHAR(100), 
     IN c VARCHAR(100), 
     IN d VARCHAR(100),
    OUT p_result INT
)
BEGIN
    SELECT
        SUM(
            IFNULL(`05~06`,0) + IFNULL(`06~07`,0) + IFNULL(`07~08`,0) +
            IFNULL(`08~09`,0) + IFNULL(`09~10`,0) + IFNULL(`10~11`,0) +
            IFNULL(`11~12`,0) + IFNULL(`12~13`,0) + IFNULL(`13~14`,0) +
            IFNULL(`14~15`,0) + IFNULL(`15~16`,0) + IFNULL(`16~17`,0) +
            IFNULL(`17~18`,0) + IFNULL(`18~19`,0) + IFNULL(`19~20`,0) +
            IFNULL(`20~21`,0) + IFNULL(`21~22`,0) + IFNULL(`22~23`,0) +
            IFNULL(`23~24`,0) + IFNULL(`24~`,0)
        )
    INTO p_result
    FROM seoul_metro_temp
    WHERE `날짜` = a
      AND `역번호` = b
      AND `역명` = c
      AND `구분` = d
     LIMIT 1;
END;
//

DELIMITER ;
```
사용
```
SET @result = 0;
CALL pl_total('2008-01-01', '150', '서울역(150)', '승차', @result);

SELECT @result
```